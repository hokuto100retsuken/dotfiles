# Neovim
# lazy-lock.json is tracked to ensure consistent plugin versions across environments
# lazy-lock.jsonは環境間で一貫したプラグインバージョンを確保するために追跡されます

# Fish shell: fisherが管理するプラグインの関数は無視、自作関数だけ追跡する
config/fish/functions/*
!config/fish/functions/fish_prompt.fish

# Fish shell: シークレット類（実値）。テンプレ(secrets.fish.example)のみ追跡する
config/fish/conf.d/secrets.fish

# バックアップファイル
*.bak
*.back
*.backup
*.old
*.orig
*.swp
*.tmp

# OS固有ファイル
.DS_Store
Thumbs.db

# エディタ固有ファイル
.vscode/
.idea/
*.sublime-*

# 一時ファイル
*.log

# Playwright MCP のローカルキャッシュ
.playwright-mcp/