[core]
	editor = nvim
[ghq]
	root = ~/src
[ghq]
  root = ~/src
[ghq "CODECOMMIT-URL"]
  vcs = git
[core]
  autocrlf = false
  quotepath = false
[color]
  ui = true
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[alias]
  aliases = "!git config --get-regexp ^alias\\. | sed 's/^alias\\.//; s/ /\t= /' | sort"
  s = status -sb
  d = diff
  dc = diff --cached
  l = log --oneline --graph -20
  la = log --oneline --graph --all -20
  co = checkout
  sw = switch
  swc = switch -c
  unstage = reset HEAD --
  amend = commit --amend --no-edit
  wip = "!git add -A && git commit -m 'wip'"
  pushf = push --force-with-lease
  delete-merged-branch = "!f () { git checkout $1; git branch --merged|egrep -v '\\*|develop|main|master'|xargs git branch -d; };f"
  branch-date = "!f() { git checkout -b $(git config user.name)-$(date +'%Y%m%d%H%M%S'); }; f"
[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only --features=interactive

[delta]
    features = decorations

[delta "interactive"]
    keep-plus-minus-markers = false

[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = omit
    hunk-header-decoration-style = blue box
    hunk-header-file-style = red
    hunk-header-line-number-style = "#067a00"
    hunk-header-style = file line-number syntax
